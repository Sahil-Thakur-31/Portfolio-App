# Public Supabase Keys (Exposed to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Private Supabase Keys (Server-side only, bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# CRON Secret for Keep-Alive endpoint protection
CRON_SECRET=your-secret-keepalive-cron-token

# Resend API Key for Lead Notification Emails
RESEND_API_KEY=your-resend-api-key

# Discord Webhook URL for Lead Alerts
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token

# Fallback recipient for lead notification emails when a resume has no contact email set
FALLBACK_LEAD_EMAIL=you@example.com

# Upstash Redis Keys for Rate Limiting
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-rest-token"

# GitHub token (used server-side, e.g. for GitHub API calls)
GITHUB_TOKEN=your-github-personal-access-token
